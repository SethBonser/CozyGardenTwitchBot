# Twitch OAuth token for the bot account (get from https://twitchtokengenerator.com or https://id.twitch.tv/oauth2/authorize)
# Must include chat:read and chat:edit scopes
BOT_USERNAME=your_bot_username
OAUTH_TOKEN=oauth:your_token_here

# The channel to join (without #)
CHANNEL_NAME=your_channel_name

# ─── Currency mode switch ────────────────────────────────────────────────────
# true  (default) — actions are triggered by Twitch channel point rewards (free)
# false           — actions are triggered by chat commands and cost petals
USE_CHANNEL_REWARDS=true

# Channel Point Reward IDs (only used when USE_CHANNEL_REWARDS=true)
# Leave blank — IDs are printed to console on first redemption so you can fill them in
GET_SEED_REWARD_ID=
RARE_SEED_REWARD_ID=
WATER_REWARD_ID=
HARVEST_REWARD_ID=
EXPAND_PLOT_REWARD_ID=

# ─── Petals-mode pricing (only used when USE_CHANNEL_REWARDS=false) ──────────
# Petals granted to a new player when they run !startgarden
STARTER_PETALS=100
# Cost of !buy seed (random: 60% common / 30% uncommon / 10% rare)
SEED_COST=30
# Cost of !buy uncommon seed (75% uncommon / 25% rare — never common)
UNCOMMON_SEED_COST=100
# Cost of !buy rare seed (guaranteed rare)
RARE_SEED_COST=200
# Cost of !water [slot]
WATER_COST=5
# Cost of !buy fertilize <slot> — applies to an empty slot, halves the
# water requirements for the next plant at every stage. Petals-only feature.
FERTILIZE_COST=300
# Base for the expand cost. Cost = EXPAND_COST_BASE × currentSize² (quadratic).
# Default 100 → 3→4 = 900, 4→5 = 1600, 5→6 = 2500, 9→10 = 8100.
EXPAND_COST_BASE=100
# Cost of !buyrain — waters every occupied slot once
RAIN_COST=200
# Cost of !buytonic <slot> — next !water on that slot counts as 3 waters
TONIC_COST=150

# Max garden slots (default: 10)
MAX_GARDEN_SLOTS=10

# Port for the OBS overlay server (default: 8080)
# Add http://localhost:<PORT>/ as a Browser Source in OBS
OVERLAY_PORT=8080

# ─── Viewer Dashboard ────────────────────────────────────────────────────────
# Set to true to expose the dashboard at a public URL via localtunnel.
# The public URL is printed to the console and announced in chat on startup.
# Requires: npm install localtunnel
# Leave false (default) to keep the dashboard local-only at http://localhost:<OVERLAY_PORT>/dashboard
DASHBOARD_TUNNEL=false

# How recently someone must have chatted to count as a "current viewer" who
# shares the harvest payout, in minutes (default: 30)
ACTIVE_VIEWER_WINDOW_MIN=30

# Comma-separated list of usernames to ignore (other chat bots, etc.)
# These users won't be tracked as active viewers and won't receive petals.
# The CozyGardenBot's own account is always ignored automatically.
# Example: IGNORED_USERS=nightbot,streamelements,moobot,fossabot
IGNORED_USERS=

# ─── Watering cooldowns ──────────────────────────────────────────────────────
# Set to false to disable cooldowns entirely (useful for testing)
WATER_COOLDOWN_ENABLED=true
# Base cooldown in minutes (default: 10)
WATER_COOLDOWN_MINUTES=10
# Cooldown with Copper Can upgrade purchased (default: 8)
COPPER_CAN_COOLDOWN_MINUTES=8
# Cooldown with Silver Can upgrade purchased (default: 6)
SILVER_CAN_COOLDOWN_MINUTES=6

# Diagnostics — leave blank/false unless troubleshooting
# DEBUG_TMI=true       # Log raw IRC traffic from tmi.js (very noisy)
# DEBUG_REWARDS=true   # Log every chat message's reward-tag presence/absence
