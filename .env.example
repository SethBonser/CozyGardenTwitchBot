# Twitch OAuth token for the bot account (get from https://twitchtokengenerator.com or https://id.twitch.tv/oauth2/authorize)
# Must include chat:read and chat:edit scopes
BOT_USERNAME=your_bot_username
OAUTH_TOKEN=oauth:your_token_here

# The channel to join (without #)
CHANNEL_NAME=your_channel_name

# Channel Point Reward IDs
# Leave blank — IDs are printed to console on first redemption so you can fill them in
GET_SEED_REWARD_ID=
RARE_SEED_REWARD_ID=
WATER_REWARD_ID=
HARVEST_REWARD_ID=
EXPAND_PLOT_REWARD_ID=

# Max garden slots (default: 10)
MAX_GARDEN_SLOTS=10

# Port for the OBS overlay server (default: 8080)
# Add http://localhost:<PORT>/ as a Browser Source in OBS
OVERLAY_PORT=8080
